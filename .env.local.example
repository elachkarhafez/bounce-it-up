# ============================================================
# BOUNCE IT UP — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- STRIPE (Required for all payments + Apple Pay) --------
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_PASTE_YOUR_STRIPE_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ---- SITE URL (Required for checkout redirects) ------------
NEXT_PUBLIC_BASE_URL=https://bounce-it-up-livonia.vercel.app

# ---- EMAIL (Required for hiring form) ----------------------
# Gmail: enable 2FA, then create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=PASTE_YOUR_GMAIL_ADDRESS_HERE
SMTP_PASS=PASTE_YOUR_GMAIL_APP_PASSWORD_HERE

# Where hiring applications get sent (defaults to SMTP_USER if blank)
HIRING_EMAIL=PASTE_HIRING_EMAIL_HERE
