# ── Stripe ─────────────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Copy this file to .env.local and fill in your real values.
STRIPE_SECRET_KEY=PASTE_YOUR_STRIPE_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ── Authorize.net ───────────────────────────────────────────────────────────
# Get your keys from: https://developer.authorize.net
NEXT_PUBLIC_AUTHORIZENET_API_LOGIN_ID=PASTE_YOUR_API_LOGIN_ID_HERE
NEXT_PUBLIC_AUTHORIZENET_CLIENT_KEY=PASTE_YOUR_CLIENT_KEY_HERE
# Use "SANDBOX" for testing, "PRODUCTION" when going live
NEXT_PUBLIC_AUTHORIZENET_ENVIRONMENT=SANDBOX

# ── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
